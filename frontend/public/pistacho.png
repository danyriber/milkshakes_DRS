<?xml version="1.0" encoding="UTF-8"?>
<svg width="200" height="200" viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg">
  <!-- Fondo degradado pistacho -->
  <defs>
    <linearGradient id="grad6" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#98D98E;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#6B8E6B;stop-opacity:1" />
    </linearGradient>
  </defs>
  
  <!-- Vaso -->
  <ellipse cx="100" cy="50" rx="35" ry="15" fill="none" stroke="white" stroke-width="2"/>
  <path d="M 65 50 L 60 150 Q 100 170 140 150 L 135 50" fill="url(#grad6)" stroke="white" stroke-width="2"/>
  <ellipse cx="100" cy="150" rx="40" ry="20" fill="#6B8E6B" stroke="white" stroke-width="2"/>
  
  <!-- Crema pistacho -->
  <ellipse cx="100" cy="45" rx="35" ry="12" fill="#FFFACD"/>
  
  <!-- Textura pistacho -->
  <path d="M 85 80 Q 87 95 88 110" stroke="#556B2F" stroke-width="1.5" fill="none" opacity="0.4"/>
  <path d="M 115 85 Q 113 100 112 115" stroke="#556B2F" stroke-width="1.5" fill="none" opacity="0.4"/>
  <path d="M 100 75 Q 102 90 100 110" stroke="#556B2F" stroke-width="1.5" fill="none" opacity="0.4"/>
  
  <!-- Brillo -->
  <ellipse cx="80" cy="65" rx="8" ry="15" fill="white" opacity="0.3"/>
</svg>
