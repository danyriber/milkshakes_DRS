<?xml version="1.0" encoding="UTF-8"?>
<svg width="200" height="200" viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg">
  <!-- Fondo degradado chocolate -->
  <defs>
    <linearGradient id="grad2" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#8B4513;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#3E2723;stop-opacity:1" />
    </linearGradient>
  </defs>
  
  <!-- Vaso -->
  <ellipse cx="100" cy="50" rx="35" ry="15" fill="none" stroke="white" stroke-width="2"/>
  <path d="M 65 50 L 60 150 Q 100 170 140 150 L 135 50" fill="url(#grad2)" stroke="white" stroke-width="2"/>
  <ellipse cx="100" cy="150" rx="40" ry="20" fill="#3E2723" stroke="white" stroke-width="2"/>
  
  <!-- Crema chocolate -->
  <ellipse cx="100" cy="45" rx="35" ry="12" fill="#D2B48C"/>
  
  <!-- Chispas de chocolate -->
  <rect x="75" y="70" width="3" height="10" fill="#654321" transform="rotate(-20 76.5 75)"/>
  <rect x="125" y="80" width="3" height="10" fill="#654321" transform="rotate(25 126.5 85)"/>
  <circle cx="90" cy="100" r="2" fill="#654321"/>
  <circle cx="110" cy="110" r="2" fill="#654321"/>
  
  <!-- Brillo -->
  <ellipse cx="85" cy="70" rx="8" ry="15" fill="white" opacity="0.2"/>
</svg>
