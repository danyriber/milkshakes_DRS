<?xml version="1.0" encoding="UTF-8"?>
<svg width="200" height="200" viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg">
  <!-- Fondo degradado -->
  <defs>
    <linearGradient id="grad1" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#FF69B4;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#FF1493;stop-opacity:1" />
    </linearGradient>
  </defs>
  
  <!-- Vaso -->
  <ellipse cx="100" cy="50" rx="35" ry="15" fill="none" stroke="white" stroke-width="2"/>
  <path d="M 65 50 L 60 150 Q 100 170 140 150 L 135 50" fill="url(#grad1)" stroke="white" stroke-width="2"/>
  <ellipse cx="100" cy="150" rx="40" ry="20" fill="#FF1493" stroke="white" stroke-width="2"/>
  
  <!-- Crema -->
  <ellipse cx="100" cy="45" rx="35" ry="12" fill="#FFFACD" opacity="0.8"/>
  
  <!-- Decoración - cereza -->
  <circle cx="100" cy="30" r="5" fill="#DC143C"/>
  <path d="M 100 30 Q 95 20 90 15" stroke="#228B22" stroke-width="2" fill="none"/>
  
  <!-- Decoración - brillo -->
  <ellipse cx="80" cy="70" rx="8" ry="15" fill="white" opacity="0.3"/>
</svg>
