<?xml version="1.0" encoding="UTF-8"?>
<svg width="200" height="200" viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg">
  <!-- Fondo degradado avellana -->
  <defs>
    <linearGradient id="grad8" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#D2B48C;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#8B6914;stop-opacity:1" />
    </linearGradient>
  </defs>
  
  <!-- Vaso -->
  <ellipse cx="100" cy="50" rx="35" ry="15" fill="none" stroke="white" stroke-width="2"/>
  <path d="M 65 50 L 60 150 Q 100 170 140 150 L 135 50" fill="url(#grad8)" stroke="white" stroke-width="2"/>
  <ellipse cx="100" cy="150" rx="40" ry="20" fill="#8B6914" stroke="white" stroke-width="2"/>
  
  <!-- Crema avellana -->
  <ellipse cx="100" cy="45" rx="35" ry="12" fill="#FFE4B5"/>
  
  <!-- Tostado/textura -->
  <circle cx="85" cy="90" r="3" fill="#654321" opacity="0.6"/>
  <circle cx="115" cy="100" r="3" fill="#654321" opacity="0.6"/>
  <circle cx="100" cy="115" r="2.5" fill="#654321" opacity="0.5"/>
  <circle cx="90" cy="105" r="2" fill="#654321" opacity="0.5"/>
  
  <!-- Brillo -->
  <ellipse cx="80" cy="65" rx="8" ry="15" fill="white" opacity="0.35"/>
</svg>
