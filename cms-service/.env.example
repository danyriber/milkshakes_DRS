# Strapi Configuration

# Host & Port
HOST=0.0.0.0
PORT=1337

# Database Configuration
# Usa 'postgres' para producción o 'sqlite' para desarrollo
DATABASE_CLIENT=sqlite

# PostgreSQL (usa si DATABASE_CLIENT=postgres)
# DATABASE_HOST=db
# DATABASE_PORT=5432
# DATABASE_NAME=strapi
# DATABASE_USERNAME=strapi
# DATABASE_PASSWORD=strapi
# DATABASE_SSL=false

# Security Keys (genera nuevos valores para producción)
APP_KEYS=key1,key2,key3,key4
ADMIN_JWT_SECRET=ejemplo_secreto_jwt_muy_largo_y_seguro
TRANSFER_TOKEN_SALT=ejemplo_salt_transferencia

# Public URL (URL donde se accede al CMS desde el navegador)
# En desarrollo: http://localhost:1337
# En producción: https://tu-dominio.com
PUBLIC_URL=http://localhost:1337

# Node Environment
NODE_ENV=development
