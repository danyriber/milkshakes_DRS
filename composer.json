{
  "name": "milkshakes_drs/tienda-web",
  "description": "Tienda de Milkshakes - Demostración de Arquitectura Cliente-Servidor",
  "type": "project",
  "version": "1.0.0",
  "license": "MIT",
  "authors": [
    {
      "name": "Administrador de Sistemas",
      "email": "admin@milkshakesdrs.com"
    }
  ],
  "require": {
    "php": ">=7.4.0",
    "ext-session": "*",
    "ext-filter": "*"
  },
  "require-dev": {
    "phpunit/phpunit": "^9.0",
    "phpstan/phpstan": "^0.12"
  },
  "suggest": {
    "ext-pdo": "Para soporte de base de datos",
    "ext-pdo_mysql": "Para MySQL",
    "ext-curl": "Para peticiones HTTP"
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/"
    },
    "files": [
      "includes/functions.php"
    ]
  },
  "scripts": {
    "test": "phpunit",
    "analyze": "phpstan analyse *.php",
    "format": "php-cs-fixer fix ."
  },
  "keywords": [
    "php",
    "apache",
    "web-server",
    "client-server",
    "html5",
    "css3"
  ],
  "support": {
    "docs": "https://github.com/danyriber/milkshakes_DRS"
  }
}
