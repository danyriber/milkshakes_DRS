<?xml version="1.0" encoding="UTF-8"?>
<svg width="200" height="200" viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg">
  <!-- Fondo degradado Oreo -->
  <defs>
    <linearGradient id="grad5" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#1C1C1C;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#0D0D0D;stop-opacity:1" />
    </linearGradient>
  </defs>
  
  <!-- Vaso -->
  <ellipse cx="100" cy="50" rx="35" ry="15" fill="none" stroke="white" stroke-width="2"/>
  <path d="M 65 50 L 60 150 Q 100 170 140 150 L 135 50" fill="url(#grad5)" stroke="white" stroke-width="2"/>
  <ellipse cx="100" cy="150" rx="40" ry="20" fill="#0D0D0D" stroke="white" stroke-width="2"/>
  
  <!-- Crema blanca -->
  <ellipse cx="100" cy="45" rx="35" ry="12" fill="#F5F5F5"/>
  
  <!-- Galletas Oreo -->
  <circle cx="80" cy="90" r="8" fill="white" opacity="0.7"/>
  <circle cx="120" cy="105" r="8" fill="white" opacity="0.7"/>
  <circle cx="100" cy="125" r="7" fill="white" opacity="0.6"/>
  
  <!-- Brillo -->
  <ellipse cx="80" cy="70" rx="8" ry="15" fill="white" opacity="0.2"/>
</svg>
