<?xml version="1.0" encoding="UTF-8"?>
<svg width="200" height="200" viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg">
  <!-- Fondo degradado vainilla -->
  <defs>
    <linearGradient id="grad3" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#F5DEB3;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#D2B48C;stop-opacity:1" />
    </linearGradient>
  </defs>
  
  <!-- Vaso -->
  <ellipse cx="100" cy="50" rx="35" ry="15" fill="none" stroke="white" stroke-width="2"/>
  <path d="M 65 50 L 60 150 Q 100 170 140 150 L 135 50" fill="url(#grad3)" stroke="white" stroke-width="2"/>
  <ellipse cx="100" cy="150" rx="40" ry="20" fill="#DEB887" stroke="white" stroke-width="2"/>
  
  <!-- Crema vainilla -->
  <ellipse cx="100" cy="45" rx="35" ry="12" fill="#FFFACD" opacity="0.9"/>
  
  <!-- Granos de vainilla -->
  <path d="M 85 80 Q 87 95 88 110" stroke="#8B4513" stroke-width="1" fill="none" opacity="0.5"/>
  <path d="M 115 85 Q 113 100 112 115" stroke="#8B4513" stroke-width="1" fill="none" opacity="0.5"/>
  <path d="M 100 75 Q 101 90 100 110" stroke="#8B4513" stroke-width="1" fill="none" opacity="0.5"/>
  
  <!-- Brillo -->
  <ellipse cx="80" cy="70" rx="8" ry="15" fill="white" opacity="0.4"/>
</svg>
